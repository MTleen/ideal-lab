flowchart TD
    subgraph cloud["☁️ 云端 — 训练 + 复杂推理"]
        direction TB
        C1["大模型训练"]
        C2["复杂推理任务"]
        C3["模型仓库管理"]
        C4["数据汇聚分析"]
    end

    subgraph edge["📡 边缘 — 实时推理"]
        direction TB
        E1["基站侧实时推理<br/>（5G网络优化）"]
        E2["工厂产线质检<br/>（边缘摄像头+模型）"]
        E3["模型压缩部署"]
    end

    subgraph end2["📱 端侧 — 轻量推理"]
        direction TB
        D1["手机端AI助手"]
        D2["IoT传感器推理"]
        D3["嵌入式AI芯片"]
    end

    cloud -->|"模型下发"| edge
    edge -->|"数据回传"| cloud
    edge -->|"轻量模型"| end2
    end2 -->|"实时指令"| edge

    subgraph fl["🔐 联邦学习：数据不出域"]
        FL1["各节点本地训练"]
        FL2["仅上传模型参数"]
        FL3["云端聚合更新"]
        FL1 --> FL2 --> FL3
    end

    cloud -.- fl

    style cloud fill:#E3F2FD,stroke:#1565C0,color:#1a1a2e
    style edge fill:#FFF3E0,stroke:#E65100,color:#1a1a2e
    style end2 fill:#E8F5E9,stroke:#2E7D32,color:#1a1a2e
    style fl fill:#F3E5F5,stroke:#6A1B9A,color:#1a1a2e
